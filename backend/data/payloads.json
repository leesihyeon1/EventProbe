        { "id": "ssrf_5", "name": "IPv6 localhost", "payload": "http://[::1]/", "description": "IPv6 우회", "risk": "high" },
        { "id": "ssrf_6", "name": "10진수 IP", "payload": "http://2130706433/", "description": "10진수 IP 우회 (127.0.0.1)", "risk": "high" }
      ]
    },
